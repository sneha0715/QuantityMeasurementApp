# Auth Service Environment Variables - Configuration Template

# ===== DEVELOPMENT PROFILE =====
# For local development with MySQL
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8081
EUREKA_DEFAULT_ZONE=http://localhost:8761/eureka/
DB_URL=jdbc:mysql://127.0.0.1:3306/auth_service?useSSL=false&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=shravan
DB_DDL_AUTO=update
DB_POOL_MAX_SIZE=5
DB_POOL_MIN_IDLE=2
DB_POOL_CONNECTION_TIMEOUT=30000
DB_POOL_IDLE_TIMEOUT=600000
DB_POOL_MAX_LIFETIME=1800000
JWT_SECRET=mySecretKeyForJwtTokenGenerationAndValidationPurposeOnly12345
JWT_EXPIRATION_MS=86400000


