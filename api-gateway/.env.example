# Development - Local Redis
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
EUREKA_DEFAULT_ZONE=http://localhost:8761/eureka/
QUANTITY_SERVICE_NAME=quantity-service
# Dev: direct URL to quantity microservice backend
QUANTITY_SERVICE_URI=http://localhost:8082

# Prod: use Eureka service discovery
# QUANTITY_SERVICE_URI=lb://quantity-service
AUTH_SERVICE_NAME=auth-service
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
GATEWAY_RETRY_RETRIES=2
GATEWAY_AUTH_RATE_PER_SEC=20
GATEWAY_AUTH_BURST_CAPACITY=40
GATEWAY_QUANTITY_RATE_PER_SEC=30
GATEWAY_QUANTITY_BURST_CAPACITY=60




