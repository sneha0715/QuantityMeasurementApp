{
  "info": {
    "name": "Quantity Measurement API",
    "description": "Postman collection to test all Quantity Measurement endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Compare quantities",
      "request": {
        "method": "POST",         "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"thisQuantityDTO\": {\n    \"value\": 1.0,\n    \"unit\": \"FEET\",\n    \"measurementType\": \"LengthUnit\"\n  },\n  \"thatQuantityDTO\": {\n    \"value\": 12.0,\n    \"unit\": \"INCHES\",\n    \"measurementType\": \"LengthUnit\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/quantities/compare",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "quantities", "compare"]
        }
      }
    },
    {
      "name": "Convert quantity",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"thisQuantityDTO\": {\n    \"value\": 1.0,\n    \"unit\": \"GALLON\",\n    \"measurementType\": \"VolumeUnit\"\n  },\n  \"thatQuantityDTO\": {\n    \"value\": 0.0,\n    \"unit\": \"LITRE\",\n    \"measurementType\": \"VolumeUnit\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/quantities/convert",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "quantities", "convert"]
        }
      }
    },
    {
      "name": "Add quantities",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"thisQuantityDTO\": {\n    \"value\": 2.0,\n    \"unit\": \"KILOGRAM\",\n    \"measurementType\": \"WeightUnit\"\n  },\n  \"thatQuantityDTO\": {\n    \"value\": 500.0,\n    \"unit\": \"GRAM\",\n    \"measurementType\": \"WeightUnit\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/quantities/add",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "quantities", "add"]
        }
      }
    },
    {
      "name": "Subtract quantities",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"thisQuantityDTO\": {\n    \"value\": 10.0,\n    \"unit\": \"LITRE\",\n    \"measurementType\": \"VolumeUnit\"\n  },\n  \"thatQuantityDTO\": {\n    \"value\": 250.0,\n    \"unit\": \"MILLILITRE\",\n    \"measurementType\": \"VolumeUnit\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/quantities/subtract",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "quantities", "subtract"]
        }
      }
    },
    {
      "name": "Divide quantities",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"thisQuantityDTO\": {\n    \"value\": 9.0,\n    \"unit\": \"FEET\",\n    \"measurementType\": \"LengthUnit\"\n  },\n  \"thatQuantityDTO\": {\n    \"value\": 3.0,\n    \"unit\": \"FEET\",\n    \"measurementType\": \"LengthUnit\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/quantities/divide",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "quantities", "divide"]
        }
      }
    },
    {
      "name": "History by operation",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/quantities/history/operation/COMPARE",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "quantities", "history", "operation", "COMPARE"]
        }
      }
    },
    {
      "name": "History by measurement type",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/quantities/history/type/LengthUnit",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "quantities", "history", "type", "LengthUnit"]
        }
      }
    },
    {
      "name": "Errored history",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/quantities/history/errored",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "quantities", "history", "errored"]
        }
      }
    },
    {
      "name": "Operation count",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/quantities/count/DIVIDE",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "quantities", "count", "DIVIDE"]
        }
      }
    }
  ]
}
