# Eureka Server Environment Variables - Configuration Template

# Development
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8761
EUREKA_HOST=localhost
EUREKA_DEFAULT_ZONE=http://localhost:8761/eureka/

# Production - Change these values
# SPRING_PROFILES_ACTIVE=prod
# EUREKA_HOST=your-eureka-prod-host
# EUREKA_DEFAULT_ZONE=http://your-eureka-prod:8761/eureka/
